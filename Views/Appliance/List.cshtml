@model ApplianceListViewModel

<section class="hero">
    <h1>Moderniza Tu Estilo de Vida</h1>
    <p>Ofrecemos electrodomésticos de alta calidad cuando los necesites. Con nosotros, obtienes precisión, rapidez y comodidad en cada paso.</p>
    <a href="#" class="btn-contact" style="display:inline-block; margin-top: 1rem;">Más Información</a>
    <div class="hero-image" style="background-image: url('/images/hero_appliances.png');"></div>
</section>

<div class="appliance-grid">
    @foreach (var appliance in Model.Appliances)
    {
        <div class="appliance-card">
            <a asp-controller="Appliance" asp-action="Details" asp-route-id="@appliance.ApplianceId">
                <img src="@appliance.ImageUrl" alt="@appliance.Name" />
            </a>
            <div class="appliance-info">
                <h3>
                    <a asp-controller="Appliance" asp-action="Details" asp-route-id="@appliance.ApplianceId">@appliance.Name</a>
                </h3>
                <p>@appliance.ShortDescription</p>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <span class="price fw-bold">@appliance.Price.ToString("C")</span>
                    <a asp-controller="Appliance" asp-action="Details" asp-route-id="@appliance.ApplianceId"
                       class="btn btn-outline-primary btn-sm">Ver Detalles</a>
                </div>
            </div>
        </div>
    }
</div>
