@{
    ViewData["Title"] = "Sobre Nosotros";
}

<div class="about-hero" style="background-image: url('/images/about_hero.png');">
    <div class="hero-overlay">
        <h1>Transformando tu Hogar</h1>
        <p>Llevamos la última tecnología a cada rincón de tu casa.</p>
    </div>
</div>

<div class="about-container">
    <section class="profile-section">
        <div class="profile-image-container">
            <img src="/images/josue_profile.png" alt="Josue David Kennedy" />
        </div>
        <div class="profile-details">
            <nav aria-label="breadcrumb">
                <span style="color: var(--accent-color); font-weight: 700; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 2px;">Fundador & Liderazgo</span>
            </nav>
            <h2>Josue David Kennedy</h2>
            <span class="subtitle">Desarrollador Fullstack & Mobile</span>
            
            <p>Desarrollador apasionado con más de 2 años de experiencia construyendo aplicaciones web, móviles y sistemas de información a medida. Mi enfoque se centra en entregar soluciones funcionales desde el diseño hasta el despliegue, trabajando estrechamente con clientes para transformar ideas en realidad.</p>
            
            <p>He liderado desarrollos multiplataforma utilizando tecnologías modernas, garantizando siempre el rendimiento, la escalabilidad y una experiencia de usuario excepcional.</p>
            
            <div class="skills-tags">
                <span class="skill-tag">Laravel</span>
                <span class="skill-tag">React Native</span>
                <span class="skill-tag">Next.js</span>
                <span class="skill-tag">Tailwind CSS</span>
                <span class="skill-tag">TypeScript</span>
                <span class="skill-tag">PHP</span>
                <span class="skill-tag">MySQL</span>
                <span class="skill-tag">Prisma</span>
            </div>
            
            <div class="actions" style="margin-top: 2rem;">
                <a href="https://www.josuekennedy.com/" target="_blank" class="btn-buy-now">Ver Portafolio</a>
                <a href="https://linkedin.com/in/josue-kennedy" target="_blank" class="btn-contact" style="margin-left: 1rem; border: 1px solid #ccc; background: transparent; color: black;">Conectar</a>
            </div>
        </div>
    </section>

    <section class="about-mission">
        <div class="section-text">
            <h2>Nuestra Misión</h2>
            <p>Bajo la visión de <strong>Josue David Kennedy</strong>, en <strong>ELECTROMODERN</strong> nuestra misión es simplificar y mejorar la vida de las personas proporcionando electrodomésticos innovadores y de alta calidad que combinan tecnología de vanguardia con un diseño elegante y funcional.</p>
        </div>
        <div class="section-stats">
            <div class="stat-card">
                <h3>2+</h3>
                <p>Años de Trayectoria</p>
            </div>
            <div class="stat-card">
                <h3>Flexible</h3>
                <p>Freelancer & Fullstack</p>
            </div>
        </div>
    </section>

    <section class="about-values">
        <h2>Nuestros Valores</h2>
        <div class="values-grid">
            <div class="value-item">
                <i class="fas fa-microchip"></i>
                <h3>Innovación</h3>
                <p>Buscamos constantemente las tecnologías más avanzadas para tu beneficio.</p>
            </div>
            <div class="value-item">
                <i class="fas fa-medal"></i>
                <h3>Calidad</h3>
                <p>Solo trabajamos con las mejores marcas y estándares de fabricación.</p>
            </div>
            <div class="value-item">
                <i class="fas fa-handshake"></i>
                <h3>Confianza</h3>
                <p>Transparencia y honestidad en cada venta y servicio post-venta.</p>
            </div>
        </div>
    </section>
</div>
