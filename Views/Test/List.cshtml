@model IEnumerable<tienda_electrodomesticos.ViewModels.CategoryAppliancesViewModel>

@{
    ViewData["Title"] = "Relación Uno-a-Muchos (Navigation)";
}

<div class="test-container" style="padding: 40px; font-family: 'Outfit', sans-serif;">
    <div style="background: linear-gradient(135deg, #0f172a 0%, #334155 100%); padding: 40px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); color: white; margin-bottom: 40px;">
        <h1 style="font-size: 2.5rem; margin-bottom: 10px;">@ViewData["Title"]</h1>
        <p style="font-size: 1.1rem; opacity: 0.8;">@ViewBag.Message</p>
    </div>

    @foreach (var category in Model)
    {
        <div style="margin-bottom: 50px;">
            <div style="display: flex; align-items: center; margin-bottom: 20px; border-left: 5px solid #3b82f6; padding-left: 15px;">
                <h2 style="font-size: 1.75rem; color: #1e293b; margin: 0;">@category.CategoryName</h2>
                <span style="margin-left: 15px; background: #dbeafe; color: #1e40af; padding: 4px 12px; border-radius: 20px; font-size: 0.9rem; font-weight: 600;">
                    @category.Appliances.Count() Productos
                </span>
            </div>

            <div style="background: white; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); overflow: hidden; border: 1px solid #e2e8f0;">
                <table style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead style="background-color: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <tr>
                            <th style="padding: 15px 20px; color: #64748b; text-transform: uppercase; font-size: 0.75rem; font-weight: 700;">Producto</th>
                            <th style="padding: 15px 20px; color: #64748b; text-transform: uppercase; font-size: 0.75rem; font-weight: 700;">Descripción</th>
                            <th style="padding: 15px 20px; color: #64748b; text-transform: uppercase; font-size: 0.75rem; font-weight: 700; text-align: right;">Precio</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!category.Appliances.Any())
                        {
                            <tr>
                                <td colspan="3" style="padding: 20px; text-align: center; color: #94a3b8; font-style: italic;">
                                    No hay productos en esta categoría.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var appliance in category.Appliances)
                            {
                                <tr class="table-row">
                                    <td style="padding: 15px 20px; font-weight: 600; color: #0f172a;">@appliance.Name</td>
                                    <td style="padding: 15px 20px; color: #64748b;">@appliance.ShortDescription</td>
                                    <td style="padding: 15px 20px; color: #3b82f6; font-weight: 700; text-align: right;">@appliance.Price.ToString("C")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div style="margin-top: 30px; text-align: center; background: #f1f5f9; padding: 20px; border-radius: 12px;">
        <p style="color: #475569; font-size: 0.95rem; margin: 0;">
            <strong>Explicación del query:</strong> Se consultan las <code>Categories</code>, se incluye su Navigation Property <code>Appliances</code> (JOIN) y se proyectan los campos necesarios.
        </p>
    </div>
</div>

<style>
    .table-row {
        border-bottom: 1px solid #f1f5f9;
        transition: background-color 0.2s ease;
    }
    .table-row:hover {
        background-color: #f8fafc;
    }
    .table-row:last-child {
        border-bottom: none;
    }
</style>
